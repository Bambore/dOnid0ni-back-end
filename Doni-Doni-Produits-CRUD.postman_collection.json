              "raw": "{\n  \"nom\": \"Doe\",\n  \"prenom\": \"John\",\n  \"email\": \"john.doe@example.com\",\n  \"telephone\": \"+2250102030405\",\n  \"profilId\": \"profil-uuid-here\",\n  \"roleIds\": [\"role-uuid-here\"]\n}"
