              "raw": "{\n  \"page\": 0,\n  \"size\": 10,\n  \"sortBy\": \"prix\",\n  \"sortDirection\": \"DESC\",\n  \"criteria\": [\n    {\n      \"field\": \"prix\",\n      \"operation\": \"GREATER_THAN\",\n      \"value\": 1000\n    },\n    {\n      \"field\": \"nom\",\n      \"operation\": \"LIKE\",\n      \"value\": \"MacBook\"\n    },\n    {\n      \"field\": \"deleted\",\n      \"operation\": \"EQUALS\",\n      \"value\": false\n    }\n  ]\n}"
